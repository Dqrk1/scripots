-- 1. Alte WindUI GUIs aus gethui() und CoreGui löschen, um Überlappungen zu vermeiden
local target = (gethui and gethui()) or game:GetService("CoreGui")
for _, v in ipairs(target:GetChildren()) do
    if v:IsA("ScreenGui") and (v.Name:match("WindUI") or v.Name == "ScreenGui") then
        v:Destroy()
    end
end

local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

game:GetService("GuiService"):SetGameplayPausedNotificationEnabled(false)

-- Remote Events
local Events = ReplicatedStorage:WaitForChild("Events", 5)
local AddSpeedEvent = Events and Events:WaitForChild("AddSpeed", 5)
local RequestRebirthEvent = Events and Events:WaitForChild("RequestRebirth", 5)

if not AddSpeedEvent or not RequestRebirthEvent then
    warn("[FarmSpeed UI]: Events konnten nicht geladen werden!")
    return
end

-- Zentrale Koordinaten
local TREADMILL_POS = Vector3.new(-1113.142333984375, 0.4415562152862549, 189.47830200195312)

-- Zustände und getrennte Delays
local autoFarmSpeed = false
local speedFireDelay = 0.2

local autoRebirth = false
local rebirthDelay = 2.0

local autoFarmWins = false
local teleportFireDelay = 1.2 -- Standardmäßig auf sichere 1.2s gesetzt, da alle Knöpfe geerntet werden

-- Partikel und Schweif-Zustände
local disablePopups = false
local popupsConnection

local disableTrail = false
local trailConnection

-- Hilfsfunktion für sicheren Teleport
local function safeTeleport(position)
    local character = LocalPlayer.Character
    if character then
        local root = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if root and humanoid and humanoid.Health > 0 then
            root.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
        end
    end
end

