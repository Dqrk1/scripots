-- --- MAIN TAB ---

MainTab:Toggle({
    Title = "Auto Farm Speed",
    Desc = "Continuously fires AddSpeed",
    Value = false,
    Callback = function(state)
        autoFarmSpeed = state

        if autoFarmSpeed then
            task.spawn(function()
                while autoFarmSpeed do
                    pcall(function()
                        AddSpeedEvent:FireServer()
                    end)
                    task.wait(speedFireDelay)
                end
            end)
        end
    end
})

MainTab:Slider({
    Title = "Fire Delay",
    Desc = "Lower = faster (Recommended: >= 0.05)",
    Value = {
        Min = 0.01,
        Max = 1,
        Default = 0.2,
    },
    Step = 0.01,
    Callback = function(value)
        speedFireDelay = value
    end
})

MainTab:Toggle({
    Title = "Auto Rebirth",
    Desc = "Continuously invokes rebirth",
    Value = false,
    Callback = function(state)
        autoRebirth = state

        if autoRebirth then
            task.spawn(function()
                while autoRebirth do
                    pcall(function()
                        RequestRebirthEvent:InvokeServer()
                    end)
                    task.wait(rebirthDelay)
                end
            end)
        end
    end
})

MainTab:Toggle({
    Title = "Disable Popups",
    Desc = "Removes floating shoes and +Speed texts",
    Value = false,
    Callback = function(state)
        disablePopups = state
        
        if disablePopups then
            local gui = LocalPlayer.PlayerGui:FindFirstChild("GUI")
            if gui then
                for _, child in ipairs(gui:GetChildren()) do
                    if child.Name == "PopUp" then
                        child:Destroy()
                    end
                end
            end
            
            if not popupsConnection and gui then
                popupsConnection = gui.ChildAdded:Connect(function(child)
                    if disablePopups and child.Name == "PopUp" then
                        task.defer(function()
                            child:Destroy()
                        end)
                    end
                end)
            end
        else
            if popupsConnection then
                popupsConnection:Disconnect()
                popupsConnection = nil
            end
        end
    end
})

MainTab:Toggle({
    Title = "Disable Trail",
    Desc = "doesnt work rn ",
    Value = false,
    Callback = function(state)
        disableTrail = state
        
        if LocalPlayer.Character then
            local trail = LocalPlayer.Character:FindFirstChild("PlayerTrail")
            if trail then
                trail.Enabled = not disableTrail
            end
        end
        
        if disableTrail then
            if not trailConnection then
                trailConnection = LocalPlayer.CharacterAdded:Connect(function(char)
                    task.wait(1)
                    local trail = char:FindFirstChild("PlayerTrail")
                    if trail then
                        trail.Enabled = not disableTrail
                    end
                end)
            end
        else
            if trailConnection then
                trailConnection:Disconnect()
                trailConnection = nil
            end
        end
    end
})

-- --- TELEPORT TAB ---

local winFarmConnection
local isLocked = false
local lockedCFrame = nil

TeleportTab:Toggle({
    Title = "Auto Farm Wins (Smart)",
    Desc = "Farms wins when standing. Pauses automatically when walking!",
    Value = false,
    Callback = function(state)
        autoFarmWins = state

        if autoFarmWins then
            local character = LocalPlayer.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local root = character and character:FindFirstChild("HumanoidRootPart")
            if not root or not humanoid then
                warn("[FarmSpeed UI]: Character/Humanoid not found!")
                autoFarmWins = false
                return
            end

            -- Heartbeat Connection: Lockt Spieler nur beim Stillstehen
            local RunService = game:GetService("RunService")
            winFarmConnection = RunService.Heartbeat:Connect(function()
                if not autoFarmWins then return end
                
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local r = char and char:FindFirstChild("HumanoidRootPart")
                
                if r and hum then
                    if hum.MoveDirection.Magnitude == 0 then
                        if not isLocked then
                            lockedCFrame = r.CFrame
                            isLocked = true
                        end
                        r.CFrame = lockedCFrame
                        r.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        r.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    else
                        isLocked = false
                        lockedCFrame = nil
                    end
                end
            end)

            -- Win Farm Loop
            task.spawn(function()
                while autoFarmWins do
                    local char = LocalPlayer.Character
                    local hum = char and char:FindFirstChildOfClass("Humanoid")
                    local r = char and char:FindFirstChild("HumanoidRootPart")
                    local giveWins = game.Workspace:FindFirstChild("GiveWins")

                    if r and hum and hum.MoveDirection.Magnitude == 0 and isLocked and giveWins then
                        -- Touch auf ALLE Knöpfe gleichzeitig im selben Frame!
                        for _, button in ipairs(giveWins:GetChildren()) do
                            local touchPart = button:FindFirstChild("Touch")
                            if touchPart then
                                if firetouchinterest then
                                    firetouchinterest(r, touchPart, 0)
                                    firetouchinterest(r, touchPart, 1)
                                end
                            end
                        end
                    end
                    task.wait(teleportFireDelay)
                end

                if winFarmConnection then
                    winFarmConnection:Disconnect()
                    winFarmConnection = nil
                end
                isLocked = false
                lockedCFrame = nil
            end)
        else
            if winFarmConnection then
                winFarmConnection:Disconnect()
                winFarmConnection = nil
            end
            isLocked = false
            lockedCFrame = nil
        end
    end
})

